# このファイルをコピーして terraform.tfvars を作成し、実際の値を入力してください
# cp terraform.tfvars.example terraform.tfvars

# AWS
aws_account_id = ""
aws_region     = "ap-northeast-1"

# ドメイン
domain_name  = ""   # 例: example.com
frontend_url = ""   # 例: https://app.example.com

# RDS
db_snapshot_identifier = ""   # 例: rds:algo-sangaku-db-2024-01-01-00-00
db_instance_class      = "db.t3.micro"
db_name                = "myapp_production"
db_username            = "postgres"

# EC2
ec2_instance_type = "t3.micro"
ec2_key_name      = ""   # SSH 不要なら空のまま

# CloudFront カスタムヘッダー (32文字以上のランダムな文字列: openssl rand -hex 32)
cloudfront_secret_header_value = ""

# Secrets (SSM Parameter Store に保存される)
rails_master_key           = ""
db_password                = ""   # 既存 RDS のパスワードと一致させる
google_client_id     = ""
google_map_api_key   = ""
paizaio_api_key            = ""
openai_api_key             = ""

# GitHub Actions OIDC
github_repo = "Alnoir-0011/algo_sangaku_back"
